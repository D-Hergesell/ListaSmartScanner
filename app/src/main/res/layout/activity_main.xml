<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical">

    <!-- Header -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="2dp"
        android:paddingVertical="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/header_title"
            android:textColor="@color/indigo"
            android:textSize="18sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Conteúdo central: três telas alternadas por visibilidade -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <include
            android:id="@+id/contentScan"
            layout="@layout/content_scan" />

        <include
            android:id="@+id/contentManual"
            layout="@layout/content_manual"
            android:visibility="gone" />

        <include
            android:id="@+id/contentProfile"
            layout="@layout/content_profile"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Bottom navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingVertical="10dp">

        <LinearLayout
            android:id="@+id/tabScan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_badge"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="6dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_qr" />

            <TextView
                android:id="@+id/tabScanLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_scan"
                android:textColor="@color/indigo"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabManual"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="6dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_edit" />

            <TextView
                android:id="@+id/tabManualLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_manual"
                android:textColor="@color/gray_600"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="6dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_user" />

            <TextView
                android:id="@+id/tabProfileLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_profile"
                android:textColor="@color/gray_600"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
