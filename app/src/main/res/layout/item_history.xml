<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false"
    android:gravity="top"
    android:orientation="horizontal"
    android:paddingVertical="10dp">

    <FrameLayout
        android:id="@+id/histIconBox"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_icon_blue">

        <ImageView
            android:id="@+id/histIcon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_edit" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/histTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                tools:text="Cadastro Manual"
                android:textColor="@color/gray_900"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/histPoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                tools:text="+5 pts"
                android:textColor="@color/gray_600"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/histDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/gray_600"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/histPurchaseDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            tools:text="Compra em 15 jun 2025"
            android:textColor="@color/gray_600"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/histDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            tools:text="Registrado em 16 jun 2025 às 14:30"
            android:textColor="@color/gray_500"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
